{
    "@context": ["https://www.w3.org/ns/wot-next/td"],
    "@type": "tm:ThingModel",
    "title": "Lamp Thing Model",
    "description": "Lamp Thing Model Description",
    "tm:optional": [
        "/events/overheating"
    ],
    "properties": {
